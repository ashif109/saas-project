// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// --- Auth & Users & Roles System ---

model User {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  email          String    @unique
  password       String
  firstName      String
  lastName       String
  name           String?   // Added to match Mongoose schema
  role           String?   @default("STUDENT") // Added to match Mongoose schema
  phone          String?
  isActive       Boolean   @default(true)
  
  // To handle multi-tenant isolation
  collegeId      String?   @map("college") @db.ObjectId
  college        College?  @relation("CollegeUsers", fields: [collegeId], references: [id], onDelete: Restrict, onUpdate: Cascade)
  
  userRoles      UserRole[]

  // References to Personas (Optional depending on roles)
  studentProfile StudentProfile?
  facultyProfile FacultyProfile?

  auditLogs      AuditLog[] @relation("UserAuditLogs")
  doubtReplies   DoubtReply[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Role {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   // "Faculty", "HOD", "Director", "Admin Staff"
  description String?
  
  permissions String[] // e.g. ["CREATE_USER", "VIEW_DEPT", "ALL"]
  
  collegeId   String   @db.ObjectId
  college     College  @relation("CollegeRoles", fields: [collegeId], references: [id], onDelete: Cascade)

  userRoles   UserRole[]

  isGlobal    Boolean  @default(false) // If true, applies across college. If false, might be scoped to department.

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model UserRole {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  userId         String    @db.ObjectId
  user           User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  roleId         String    @db.ObjectId
  role           Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  isPrimary      Boolean   @default(false)
  departmentId   String?   @db.ObjectId // Optional scope
  department     Department? @relation(fields: [departmentId], references: [id])

  validFrom      DateTime?
  validUntil     DateTime? // Time-bound role

  // Overridden permissions for this specific assignment
  extraPermissions String[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

// --- Core Modules ---

model College {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  subdomain       String   @unique
  address         String?
  logoUrl         String?
  
  users           User[]   @relation("CollegeUsers")
  roles           Role[]   @relation("CollegeRoles")
  departments     Department[]
  academicYears   AcademicYear[]
  batches         Batch[]
  notices         Notice[]
  feeStructures   FeeStructure[]
  transactions    Transaction[]
  auditLogs       AuditLog[] @relation("CollegeAuditLogs")
  admissionLeads  AdmissionLead[]
  scholarships    Scholarship[]
  attendances     Attendance[]

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Department {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   // e.g. "Computer Science"
  code        String   // e.g. "CSE"
  
  collegeId   String   @db.ObjectId
  college     College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  courses     Course[]
  faculties   FacultyProfile[]
  userRoles   UserRole[] // To link roles like HOD to this department

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Course {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  name         String   // e.g. "B.Tech Computer Science"
  duration     Int      // in years or semesters
  
  departmentId String   @db.ObjectId
  department   Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  subjects     Subject[]
  batches      Batch[]
  admissionLeads AdmissionLead[]
  feeStructures  FeeStructure[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Subject {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  code        String
  credits     Int
  
  courseId    String   @db.ObjectId
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  semester    Int // Which semester it belongs to

  facultyAssignments FacultySubject[]
  timetables         TimetableEntry[]
  attendances        Attendance[]
  internalMarks      InternalMark[]
  assignments        Assignment[]
  doubts             Doubt[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime @updatedAt
}

model AcademicYear {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   // e.g. "2023-2024"
  startDate   DateTime
  endDate     DateTime
  
  collegeId   String   @db.ObjectId
  college     College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  batches     Batch[]
  events      Event[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Batch {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String   // e.g. "2023 Batch"
  
  courseId       String   @db.ObjectId
  course         Course   @relation(fields: [courseId], references: [id], onDelete: Cascade)

  academicYearId String   @db.ObjectId
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)
  
  collegeId      String   @db.ObjectId
  college        College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  students       StudentProfile[]
  timetables     TimetableEntry[]
  attendances    Attendance[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model StudentProfile {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  enrollmentNo   String   @unique
  admissionDate  DateTime
  
  userId         String   @unique @db.ObjectId
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  batchId        String   @db.ObjectId
  batch          Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  transactions   Transaction[]
  scholarshipApplications ScholarshipApplication[]
  attendances    Attendance[]
  internalMarks  InternalMark[]
  assignmentSubmissions AssignmentSubmission[]
  doubts         Doubt[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model FacultyProfile {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  employeeId     String   @unique
  joiningDate    DateTime
  
  userId         String   @unique @db.ObjectId
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  departmentId   String   @db.ObjectId
  department     Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)

  subjects       FacultySubject[]
  timetables     TimetableEntry[]
  assignments    Assignment[]
  doubts         Doubt[]
  leaveRequests  LeaveRequest[] @relation("LeaveRequests")
  substituteRequests LeaveRequest[] @relation("SubstituteRequests")

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model FacultySubject {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  facultyId   String   @db.ObjectId
  faculty     FacultyProfile @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  subjectId   String   @db.ObjectId
  subject     Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  @@unique([facultyId, subjectId])
}

model TimetableEntry {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  dayOfWeek      String   // "Monday", "Tuesday"
  startTime      String   // "09:00"
  endTime        String   // "10:00"
  roomInfo       String?
  
  batchId        String   @db.ObjectId
  batch          Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  facultyId      String   @db.ObjectId
  faculty        FacultyProfile @relation(fields: [facultyId], references: [id], onDelete: Cascade)

  subjectId      String?  @db.ObjectId
  subject        Subject? @relation(fields: [subjectId], references: [id], onDelete: SetNull)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Notice {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  title       String
  content     String
  priority    String   @default("Standard") // Standard, Critical, Info
  audience    String   @default("Everyone") // Everyone, Students, Faculty, Staff
  
  collegeId   String   @db.ObjectId
  college     College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  targetRoles String[] // Empty means all
  targetDepts String[] // Empty means all

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Event {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  title          String
  description    String?
  startDate      DateTime
  endDate        DateTime
  isHoliday      Boolean  @default(false)
  
  academicYearId String   @db.ObjectId
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// --- newly added models ---

model AuditLog {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  action      String   // e.g. "CREATED_YEAR", "DELETED_USER"
  resource    String   // e.g. "AcademicYear", "User"
  resourceId  String?
  details     String?  // JSON string
  
  userId      String   @db.ObjectId
  user        User     @relation("UserAuditLogs", fields: [userId], references: [id], onDelete: Restrict)

  collegeId   String   @db.ObjectId
  college     College  @relation("CollegeAuditLogs", fields: [collegeId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model AdmissionLead {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  firstName   String
  lastName    String
  email       String
  phone       String?
  status      String   @default("NEW") // NEW, IN_PROGRESS, REJECTED, ENROLLED
  notes       String?
  
  courseId    String   @db.ObjectId
  course      Course   @relation(fields: [courseId], references: [id], onDelete: Restrict)

  collegeId   String   @db.ObjectId
  college     College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FeeStructure {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  name           String   // e.g. "Tuition Fee 2024"
  amount         Float
  description    String?
  
  courseId       String?  @db.ObjectId
  course         Course?  @relation(fields: [courseId], references: [id])

  collegeId      String   @db.ObjectId
  college        College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  transactions   Transaction[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Transaction {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  amount         Float
  paymentDate    DateTime @default(now())
  paymentMethod  String   // "Cash", "Online", "Bank Transfer"
  status         String   @default("PAID") // PAID, PENDING, FAILED
  receiptNo      String?  @unique
  type           String?  @default("Tuition") // Tuition, Exam Fee, etc.
  
  studentId      String   @db.ObjectId
  student        StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  feeStructureId String?  @db.ObjectId
  feeStructure   FeeStructure? @relation(fields: [feeStructureId], references: [id])

  collegeId      String   @db.ObjectId
  college        College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Scholarship {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String   // e.g. "Merit Excellence Award"
  description String?
  amount      Float
  type        String   // "Full Tuition", "Fixed Amount", "Percentage"
  status      String   @default("ACTIVE") // ACTIVE, CLOSED
  
  collegeId   String   @db.ObjectId
  college     College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  applications ScholarshipApplication[]

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ScholarshipApplication {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId      String   @db.ObjectId
  student        StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  scholarshipId  String   @db.ObjectId
  scholarship    Scholarship @relation(fields: [scholarshipId], references: [id], onDelete: Cascade)
  
  status         String   @default("PENDING") // PENDING, APPROVED, REJECTED
  appliedDate    DateTime @default(now())
  notes          String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([studentId, scholarshipId])
}

model Attendance {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  date           DateTime
  status         String   // PRESENT, ABSENT, LATE
  
  studentId      String   @db.ObjectId
  student        StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  subjectId      String   @db.ObjectId
  subject        Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  batchId        String   @db.ObjectId
  batch          Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  collegeId      String   @db.ObjectId
  college        College  @relation(fields: [collegeId], references: [id], onDelete: Cascade)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([studentId, subjectId, date])
}

// --- Faculty Panel Models ---

model InternalMark {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId     String   @db.ObjectId
  subjectId     String   @db.ObjectId
  examName      String   // e.g. "Midterm 1", "Quiz 1", "Assignment 1"
  marksObtained Float
  maxMarks      Float
  
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Assignment {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  title         String
  description   String?
  fileUrl       String?  // Optional uploaded PDF
  dueDate       DateTime
  
  subjectId     String   @db.ObjectId
  facultyId     String   @db.ObjectId
  
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  faculty       FacultyProfile @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  
  submissions   AssignmentSubmission[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model AssignmentSubmission {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  assignmentId  String   @db.ObjectId
  studentId     String   @db.ObjectId
  
  fileUrl       String?
  status        String   @default("SUBMITTED") // SUBMITTED, LATE, GRADED
  marks         Float?
  feedback      String?
  
  assignment    Assignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  @@unique([assignmentId, studentId])
}

model LeaveRequest {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  facultyId     String   @db.ObjectId
  startDate     DateTime
  endDate       DateTime
  reason        String
  status        String   @default("PENDING") // PENDING, APPROVED, REJECTED
  
  substituteId  String?  @db.ObjectId
  
  faculty       FacultyProfile @relation("LeaveRequests", fields: [facultyId], references: [id], onDelete: Cascade)
  substitute    FacultyProfile? @relation("SubstituteRequests", fields: [substituteId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Doubt {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  studentId     String   @db.ObjectId
  subjectId     String   @db.ObjectId
  facultyId     String   @db.ObjectId
  
  question      String
  status        String   @default("OPEN") // OPEN, RESOLVED
  
  student       StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)
  subject       Subject  @relation(fields: [subjectId], references: [id], onDelete: Cascade)
  faculty       FacultyProfile @relation(fields: [facultyId], references: [id], onDelete: Cascade)
  
  replies       DoubtReply[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model DoubtReply {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  doubtId       String   @db.ObjectId
  userId        String   @db.ObjectId // Can be student or faculty
  
  message       String
  
  doubt         Doubt    @relation(fields: [doubtId], references: [id], onDelete: Cascade)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
}

